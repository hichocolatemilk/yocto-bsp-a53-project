From 2659a9d7bd8770d8fd4c5a627405a56e0e8b964c Mon Sep 17 00:00:00 2001
From: OpenEmbedded <oe.patch@oe>
Date: Sat, 28 Mar 2026 21:21:08 +0900
Subject: [PATCH] bcm2710 rpi3b+ uart0, bt_pins: disabled led_act: heartbeat

---
 arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b-plus.dts | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b-plus.dts b/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b-plus.dts
index 8973985e9902..07d4a21f3f26 100644
--- a/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b-plus.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b-plus.dts
@@ -122,6 +122,7 @@ bt_pins: bt_pins {
 		brcm,pins = <43>;
 		brcm,function = <4>; /* alt0:GPCLK2 */
 		brcm,pull = <0>;
+		status = "disabled";
 	};
 
 	uart0_pins: uart0_pins {
@@ -182,7 +183,7 @@ expgpio: expgpio {
 
 &uart0 {
 	pinctrl-names = "default";
-	pinctrl-0 = <&uart0_pins &bt_pins>;
+	pinctrl-0 = <&uart0_pins>;
 	status = "okay";
 };
 
@@ -236,7 +237,7 @@ &i2s {
 &led_act {
 	gpios = <&gpio 29 GPIO_ACTIVE_HIGH>;
 	default-state = "off";
-	linux,default-trigger = "mmc0";
+	linux,default-trigger = "heartbeat";
 };
 
 &leds {
